{
  "sync_name": "Salesforce Account Health Sync",
  "source_model": "ANALYTICS.marts.dim_customers",
  "destination": "Salesforce Accounts CRM",
  "sync_mode": "upsert",
  "primary_key": "salesforce_account_id",
  "api_limit_tuning": {
    "bulk_batch_size": 10000,
    "max_concurrent_connections": 5
  },
  "alerting": {
    "on_failure": [
      "data-alerts@company.com"
    ]
  },
  "delta_tracking": {
    "method": "primary_key_comparisons"
  },
  "mappings": {
    "salesforce_account_id": "Id",
    "customer_health_score": "Health_Score__c",
    "total_ltv_dollars": "LTV__c",
    "customer_email": "Primary_Email__c"
  }
}
